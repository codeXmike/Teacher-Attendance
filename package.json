{
  "name": "teacher-attendance-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @attendance/api run dev",
    "dev:web": "npm --workspace @attendance/web run dev",
    "dev:student-mobile": "npm --workspace @attendance/student-mobile run dev",
    "dev:student-android": "npm --workspace @attendance/student-mobile run android",
    "dev:electron": "npm --workspace @attendance/electron run dev",
    "build": "npm run build:web && npm run build:api && npm run build:electron",
    "build:api": "npm --workspace @attendance/api run build",
    "build:web": "npm --workspace @attendance/web run build",
    "build:electron": "npm --workspace @attendance/electron run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
